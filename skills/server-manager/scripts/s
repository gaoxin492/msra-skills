#!/usr/bin/env bash
# 服务器快捷登录脚本 - s <别名>
# 通过 AzureML WSS relay 连接服务器
# 使用前请填写下方集群配置
set -euo pipefail

JUMPBOX="msra"          # ← 改成你的跳板机 SSH 别名
KEY="~/.ssh/id_rsa"     # ← 跳板机上的私钥路径

# ══════════════════════════════════════
# 在此配置你的集群（按需添加/删除）
# ══════════════════════════════════════

# ── 集群 A ──
A_USER="your_email@microsoft.com"    # ← 跳板机上 sudo su 的用户
A_JOB="your_job_name_here"           # ← az ml job 名
A_WORKSPACE="your-workspace"
A_RG="your-resource-group"
A_SUB="your-subscription-id"

# ── 集群 B ──（不需要就删掉）
# B_USER="your_email@microsoft.com"
# B_JOB="your_job_name_here"
# B_WORKSPACE="your-workspace"
# B_RG="your-resource-group"
# B_SUB="your-subscription-id"

# ══════════════════════════════════════

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

connect_azml() {
    local user="$1" job="$2" node="$3" ws="$4" rg="$5" sub="$6"
    echo -e "${CYAN}Connecting to ${BOLD}${job}${NC}${CYAN} (node ${node})...${NC}"

    if [ "$user" = "DIRECT" ]; then
        ssh -t "$JUMPBOX" "az account set --subscription ${sub} && \
            cd ~ && az ml job connect-ssh \
            --name ${job} --node-index ${node} \
            --private-key-file-path ${KEY} \
            --workspace-name ${ws} --resource-group ${rg} \
            --subscription ${sub}"
    else
        ssh -t "$JUMPBOX" "sudo -u ${user} bash -c 'cd ~ && az ml job connect-ssh \
            --name ${job} --node-index ${node} \
            --private-key-file-path ${KEY} \
            --workspace-name ${ws} --resource-group ${rg} \
            --subscription ${sub}'"
    fi
}

show_list() {
    echo -e "${BOLD}========== 服务器列表 ==========${NC}"
    echo ""
    # ── 直连 SSH 服务器 ──
    # echo -e "${BOLD}直连服务器${NC}"
    # echo -e "  ${GREEN}pi${NC}      树莓派 (moss.local)"
    # echo -e "  ${GREEN}dev${NC}     开发机 (192.168.1.100)"
    # echo ""
    # ── AzureML 集群 ──
    echo -e "${BOLD}集群 A${NC}"
    echo -e "  ${GREEN}a0${NC}    node0"
    echo -e "  ${GREEN}a1${NC}    node1"
    echo ""
    # 按需添加更多集群...
    echo -e "${BOLD}其他${NC}"
    echo -e "  ${GREEN}msra${NC}      跳板机"
    echo ""
    echo -e "用法: ${CYAN}s <别名>${NC}  例如: s a0, s pi"
    echo -e "      ${CYAN}s check${NC}  一键巡检所有服务器状态和 GPU"
}

case "${1:-}" in
    list|ls|"")
        show_list
        ;;
    # ── 直连 SSH 服务器（最简单，只需 ssh 别名/IP）──
    # pi)
    #     ssh pi            # 使用 ~/.ssh/config 中的配置
    #     ;;
    # dev)
    #     ssh user@192.168.1.100
    #     ;;
    # ── AzureML 集群（通过跳板机 + WSS relay）──
    a0)
        connect_azml "$A_USER" "$A_JOB" 0 "$A_WORKSPACE" "$A_RG" "$A_SUB"
        ;;
    a1)
        connect_azml "$A_USER" "$A_JOB" 1 "$A_WORKSPACE" "$A_RG" "$A_SUB"
        ;;
    # b0)
    #     connect_azml "$B_USER" "$B_JOB" 0 "$B_WORKSPACE" "$B_RG" "$B_SUB"
    #     ;;
    msra)
        ssh msra
        ;;
    check)
        shift
        s-check "${1:-all}"
        ;;
    *)
        echo -e "${RED}Unknown server: $1${NC}"
        echo ""
        show_list
        exit 1
        ;;
esac
